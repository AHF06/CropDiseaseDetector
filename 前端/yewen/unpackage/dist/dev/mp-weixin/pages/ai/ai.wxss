.ai-chat-page.data-v-fdb58938 {
  width: 100%;
  height: 100vh;
  background: #f5f7f0;
  display: flex;
  flex-direction: column;
  position: relative;
}

/* 头部导航栏 */
.chat-header.data-v-fdb58938 {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12px 16px;
  background: linear-gradient(135deg, #2c5e2a, #3a7a36);
  color: white;
}
.chat-header .header-left.data-v-fdb58938 {
  width: 44px;
}
.chat-header .header-left .back-icon.data-v-fdb58938 {
  font-size: 28px;
  font-weight: bold;
}
.chat-header .header-center.data-v-fdb58938 {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
}
.chat-header .header-center .robot-avatar-small.data-v-fdb58938 {
  position: relative;
  width: 44px;
  height: 44px;
  background: #f7cd5c;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.chat-header .header-center .robot-avatar-small .robot-icon.data-v-fdb58938 {
  font-size: 28px;
}
.chat-header .header-center .robot-avatar-small .robot-hat-small.data-v-fdb58938 {
  position: absolute;
  top: -6px;
  left: 18px;
  font-size: 14px;
  transform: rotate(-15deg);
}
.chat-header .header-center .robot-info .robot-name.data-v-fdb58938 {
  font-size: 18px;
  font-weight: bold;
  display: block;
}
.chat-header .header-center .robot-info .robot-status.data-v-fdb58938 {
  font-size: 11px;
  opacity: 0.8;
}
.chat-header .header-right.data-v-fdb58938 {
  width: 44px;
  text-align: right;
}
.chat-header .header-right .menu-icon.data-v-fdb58938 {
  font-size: 22px;
}

/* 聊天消息区域 */
.chat-messages.data-v-fdb58938 {
  flex: 1;
  padding: 16px;
  overflow-y: auto;
}
.load-history.data-v-fdb58938 {
  text-align: center;
  padding: 10px;
  font-size: 12px;
  color: #999;
}

/* 欢迎消息 */
.welcome-message.data-v-fdb58938 {
  background: white;
  border-radius: 24px;
  padding: 24px;
  margin: 20px 0;
  text-align: center;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.05);
}
.welcome-message .welcome-icon.data-v-fdb58938 {
  font-size: 48px;
  display: block;
  margin-bottom: 12px;
}
.welcome-message .welcome-title.data-v-fdb58938 {
  font-size: 20px;
  font-weight: bold;
  color: #2c5e2a;
  display: block;
  margin-bottom: 8px;
}
.welcome-message .welcome-desc.data-v-fdb58938 {
  font-size: 14px;
  color: #666;
  display: block;
  margin-bottom: 16px;
}
.welcome-message .welcome-tip.data-v-fdb58938 {
  font-size: 13px;
  color: #999;
  display: block;
  margin-bottom: 12px;
}
.welcome-message .welcome-actions.data-v-fdb58938 {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
  justify-content: center;
}
.welcome-message .welcome-actions .welcome-btn.data-v-fdb58938 {
  padding: 8px 16px;
  background: #f0f5ea;
  border-radius: 30px;
  font-size: 13px;
  color: #2c5e2a;
}

/* 消息行 */
.message-row.data-v-fdb58938 {
  display: flex;
  margin-bottom: 16px;
}
.message-row.user.data-v-fdb58938 {
  justify-content: flex-end;
}
.message-row.assistant.data-v-fdb58938 {
  justify-content: flex-start;
}
.message-avatar.data-v-fdb58938 {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: #e8f5e9;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 10px;
  flex-shrink: 0;
}
.message-avatar.user-avatar.data-v-fdb58938 {
  background: #e3f2fd;
  margin-right: 0;
  margin-left: 10px;
}
.message-avatar .avatar-icon.data-v-fdb58938 {
  font-size: 22px;
}
.message-bubble.data-v-fdb58938 {
  max-width: 70%;
  padding: 12px 16px;
  border-radius: 20px;
  font-size: 15px;
  line-height: 1.5;
}
.message-bubble.user.data-v-fdb58938 {
  background: #2c5e2a;
  color: white;
  border-bottom-right-radius: 4px;
}
.message-bubble.assistant.data-v-fdb58938 {
  background: white;
  color: #333;
  border-bottom-left-radius: 4px;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}
.message-text.data-v-fdb58938 {
  word-break: break-all;
  white-space: pre-wrap;
}

/* 打字动画 */
.typing-indicator.data-v-fdb58938 {
  display: inline-flex;
  gap: 4px;
}
.typing-indicator .dot.data-v-fdb58938 {
  animation: blink-fdb58938 1.4s infinite;
  font-size: 20px;
}
.typing-indicator .dot.data-v-fdb58938:nth-child(2) {
  animation-delay: 0.2s;
}
.typing-indicator .dot.data-v-fdb58938:nth-child(3) {
  animation-delay: 0.4s;
}
@keyframes blink-fdb58938 {
0%, 60%, 100% {
    opacity: 0.3;
}
30% {
    opacity: 1;
}
}
.loading-bubble.data-v-fdb58938 {
  background: #e8e8e8;
}
.loading-bubble .loading-text.data-v-fdb58938 {
  font-size: 13px;
  color: #999;
}

/* 快捷回复栏 */
.quick-replies.data-v-fdb58938 {
  white-space: nowrap;
  padding: 8px 12px;
  background: transparent;
}
.quick-replies .quick-reply.data-v-fdb58938 {
  display: inline-block;
  padding: 6px 16px;
  background: white;
  border-radius: 30px;
  margin-right: 10px;
  font-size: 13px;
  color: #2c5e2a;
  border: 1px solid #e0e0e0;
  box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
}

/* 底部输入栏 */
.chat-input-bar.data-v-fdb58938 {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  background: white;
  border-top: 1px solid #f0f0e8;
  padding-bottom: calc(12px + constant(safe-area-inset-bottom));
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
}
.input-left.data-v-fdb58938 {
  display: flex;
  gap: 12px;
}
.input-left .input-icon.data-v-fdb58938 {
  width: 36px;
  height: 36px;
  background: #f5f7f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 18px;
}
.input-container.data-v-fdb58938 {
  flex: 1;
}
.input-container .chat-input.data-v-fdb58938 {
  width: 100%;
  padding: 10px 16px;
  background: #f5f7f0;
  border-radius: 30px;
  font-size: 15px;
}
.send-btn.data-v-fdb58938 {
  padding: 8px 20px;
  background: #2c5e2a;
  color: white;
  border-radius: 30px;
  font-weight: 500;
}

/* 菜单弹窗 */
.menu-modal.data-v-fdb58938 {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.3);
  z-index: 1000;
  display: flex;
  justify-content: flex-end;
  padding: 60px 16px 0 0;
}
.menu-popup.data-v-fdb58938 {
  background: white;
  border-radius: 16px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
  overflow: hidden;
}
.menu-popup .menu-item.data-v-fdb58938 {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 14px 20px;
  border-bottom: 1px solid #f0f0e8;
  font-size: 14px;
}
.menu-popup .menu-item.data-v-fdb58938:last-child {
  border-bottom: none;
}
.menu-popup .menu-item text.data-v-fdb58938:first-child {
  font-size: 18px;
}