  color: #666;
  line-height: 1.5;
}
.treatment-section.data-v-b615976f {
  margin-bottom: 16px;
}
.treatment-section .section-title.data-v-b615976f {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 10px;
  font-size: 15px;
  font-weight: 600;
  color: #333;
}
.treatment-section .section-title .section-icon.data-v-b615976f {
