/* 底部操作栏 */
.bottom-actions.data-v-b615976f {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  background: white;
  border-top: 1px solid #f0f0e8;
  padding: 12px 16px;
  padding-bottom: calc(12px + constant(safe-area-inset-bottom));
  padding-bottom: calc(12px + env(safe-area-inset-bottom));
  gap: 12px;
}
.bottom-actions .action-btn.data-v-b615976f {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px;
  border-radius: 40px;
  font-size: 13px;
  font-weight: 500;
}
.bottom-actions .action-btn.save-btn.data-v-b615976f {
  background: #2c5e2a;
  color: white;
}
.bottom-actions .action-btn.voice-btn.data-v-b615976f {
  background: #f0f5ea;
  color: #2c5e2a;
}
.bottom-actions .action-btn.consult-btn.data-v-b615976f {
  background: #f0f5ea;
  color: #2c5e2a;
}

/* 语音播报状态 */
.voice-status.data-v-b615976f {
  position: fixed;
  bottom: 100px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.85);
  border-radius: 50px;
  padding: 12px 20px;
  display: flex;
  align-items: center;
  gap: 16px;
  z-index: 1000;
}
.voice-status .voice-wave.data-v-b615976f {
  display: flex;
  align-items: center;
  gap: 4px;
}
.voice-status .voice-wave .wave.data-v-b615976f {
  width: 4px;
  height: 16px;
  background: #2c5e2a;
  border-radius: 2px;
  animation: wave-b615976f 0.8s ease-in-out infinite;
}
.voice-status .voice-wave .wave.data-v-b615976f:nth-child(1) {
  animation-delay: 0s;
}
.voice-status .voice-wave .wave.data-v-b615976f:nth-child(2) {
  animation-delay: 0.2s;
}
.voice-status .voice-wave .wave.data-v-b615976f:nth-child(3) {
  animation-delay: 0.4s;
}
.voice-status .voice-status-text.data-v-b615976f {
  color: white;
  font-size: 14px;
}
.voice-status .voice-stop.data-v-b615976f {
  padding: 4px 8px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30px;
  cursor: pointer;
}
@keyframes wave-b615976f {
0%, 100% {
    height: 16px;
}
50% {
    height: 30px;
}
}
/* 提示消息 */
.toast-message.data-v-b615976f {
  position: fixed;
  bottom: 120px;
  left: 50%;
  transform: translateX(-50%);
  background: rgba(0, 0, 0, 0.7);
  color: white;
  padding: 8px 20px;
  border-radius: 40px;
  font-size: 14px;
  z-index: 1000;
}