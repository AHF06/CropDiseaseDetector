/* 文章场景相关 */
.login-page.data-v-e4e4508d {
  min-height: 100vh;
  background: linear-gradient(135deg, #2c5e2a 0%, #4a9e46 50%, #2c5e2a 100%);
  position: relative;
  display: flex;
  flex-direction: column;
}

/* 背景装饰 */
.bg-decoration.data-v-e4e4508d {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  overflow: hidden;
}
.bg-blur.data-v-e4e4508d {
  position: absolute;
  top: -20%;
  left: -20%;
  width: 140%;
  height: 140%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0) 70%);
}

/* Logo区域 */
.logo-section.data-v-e4e4508d {
  text-align: center;
  margin-top: 80px;
  margin-bottom: 40px;
  z-index: 1;
}
.logo-icon.data-v-e4e4508d {
  width: 80px;
  height: 80px;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 24px;
  margin: 0 auto 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  -webkit-backdrop-filter: blur(10px);
          backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.3);
}
.logo-emoji.data-v-e4e4508d {
  font-size: 48px;
}
.app-name.data-v-e4e4508d {
  display: block;
  font-size: 28px;
  font-weight: bold;
  color: white;
  margin-bottom: 8px;
}
.app-slogan.data-v-e4e4508d {
  display: block;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section.data-v-e4e4508d {
  background: white;
  border-radius: 32px 32px 0 0;
  padding: 24px 20px 30px;
  margin-top: auto;
  z-index: 1;
}

/* Tab切换 */
.tab-bar.data-v-e4e4508d {
  display: flex;
  gap: 24px;
  margin-bottom: 24px;
  border-bottom: 2px solid #f0f0e8;
}
.tab-item.data-v-e4e4508d {
  font-size: 16px;
  font-weight: 500;
  color: #999;
  padding-bottom: 12px;
  position: relative;
}
.tab-item.active.data-v-e4e4508d {
  color: #2c5e2a;
}
.tab-item.active.data-v-e4e4508d::after {
  content: "";
  position: absolute;
  bottom: -2px;
  left: 0;
  right: 0;
  height: 2px;
  background: #2c5e2a;
  border-radius: 2px;
}

/* 输入框 */
.input-group.data-v-e4e4508d {
  display: flex;
  align-items: center;
  background: #f5f7f0;
  border-radius: 16px;
  padding: 12px 16px;
  margin-bottom: 16px;
}
.input-icon.data-v-e4e4508d {
  font-size: 20px;
  margin-right: 12px;
}
.input-field.data-v-e4e4508d {
  flex: 1;
  font-size: 15px;
  background: transparent;
}
.input-eye.data-v-e4e4508d {
  padding: 4px 8px;
  font-size: 18px;
}
.code-btn.data-v-e4e4508d {
  padding: 6px 12px;
  background: #2c5e2a;
  color: white;
  border-radius: 30px;
  font-size: 12px;
  white-space: nowrap;
}
.code-btn.disabled.data-v-e4e4508d {
  background: #ccc;
}

/* 表单选项 */
.form-options.data-v-e4e4508d {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24px;
}
.remember.data-v-e4e4508d {
  display: flex;
  align-items: center;
  gap: 8px;
}
.checkbox.data-v-e4e4508d {
  width: 18px;
  height: 18px;
  border-radius: 4px;
  border: 1px solid #ddd;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: white;
}
.checkbox.checked.data-v-e4e4508d {
  background: #2c5e2a;
  border-color: #2c5e2a;
}
.forgot.data-v-e4e4508d {
  color: #999;
  font-size: 13px;
}

/* 登录按钮 */
.login-btn.data-v-e4e4508d {
  width: 100%;
  padding: 14px;
  background: linear-gradient(135deg, #2c5e2a, #3a7a36);
  color: white;
  border-radius: 40px;
  font-size: 16px;
  font-weight: 600;
  border: none;
  margin-bottom: 20px;
}

